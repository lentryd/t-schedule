{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "strict": true,
    "pretty": true,
    "baseUrl": "./",
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "declaration": true,
    "esModuleInterop": true,
    "strictNullChecks": true,
    "moduleResolution": "node"
  },
  "lib": [
    "es2015"
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/methods/*.ts",
    "src/messages/*.ts"
  ]
}